# =============================================================
# pkq-server — exemplo de configuracao
# Copie este arquivo para `.env` e ajuste os valores.
# =============================================================

# Porta TCP local do WebSocket. Mantenha em 8080 a menos que ja esteja em uso.
PORT=8080

# Origens HTTP permitidas (separadas por virgula). O navegador envia o header
# `Origin` automaticamente; conexoes de origens diferentes sao recusadas.
# Inclua a URL do seu GitHub Pages e localhost para testes.
ALLOWED_ORIGINS=https://Brun0Simoes.github.io,http://localhost:8000,http://127.0.0.1:8000

# Token compartilhado (opcional, mas RECOMENDADO).
# Se definido, o cliente deve conectar em `wss://.../pkq?token=SEU_TOKEN`.
# Gere um valor longo e aleatorio (ex.: `openssl rand -hex 32`).
AUTH_TOKEN=

# Limites de seguranca
MAX_CONNECTIONS_PER_IP=8
MAX_MESSAGE_BYTES=65536
RATE_LIMIT_PER_SEC=30
HEARTBEAT_MS=30000

# TLS direto (opcional). Se setar ambos, o servidor sobe em WSS nativo.
# Para uso com tunel (Cloudflare/ngrok) deixe vazio — o tunel cuida do TLS.
# TLS_CERT_PATH=
# TLS_KEY_PATH=

# ----- Sync de save (HTTP /api/*) -----
# Diretorio onde ficam os saves (por usuario). Cria automaticamente se faltar.
SAVE_DIR=./saves

# Pepper aplicado em todos os hash de senha guardados no servidor.
# Deixe um valor longo e aleatorio. Se vazar, atacante consegue
# brute-force offline contra os hashes (que ja sao fracos).
SERVER_PEPPER=

# Tamanho maximo do body em POST /api/save (saves crescem com a Pokedex).
MAX_BODY_BYTES=524288
